{
    "name": "comet-storybook",
    "version": "1.0.0",
    "private": true,
    "description": "Storybook for Comet components",
    "license": "BSD-2-Clause",
    "files": [
        "src"
    ],
    "scripts": {
        "build-storybook": "storybook build --disable-telemetry",
        "lint": "run-p lint:prettier lint:eslint lint:tsc",
        "lint:ci": "pnpm run lint",
        "lint:eslint": "eslint --max-warnings 0 src/ '**/*.json' .storybook/ --no-warn-ignored",
        "lint:fix": "run-p lint:fix:eslint lint:fix:prettier",
        "lint:fix:eslint": "pnpm run lint:eslint --fix",
        "lint:fix:prettier": "pnpm run lint:prettier --write",
        "lint:prettier": "pnpm exec prettier --check '*.{ts,js,json,md,yml,yaml}'",
        "lint:tsc": "tsc --noEmit",
        "storybook": "storybook dev -p 26638 --no-version-updates --disable-telemetry",
        "test": "pnpm run test:storybook",
        "test:storybook": "vitest --run",
        "test:watch": "vitest --watch"
    },
    "dependencies": {
        "@apollo/client": "^3.14.1",
        "@comet/admin": "workspace:*",
        "@comet/admin-color-picker": "workspace:*",
        "@comet/admin-date-time": "workspace:*",
        "@comet/admin-icons": "workspace:*",
        "@comet/admin-rte": "workspace:*",
        "@comet/cms-admin": "workspace:*",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource-variable/roboto-flex": "^5.2.8",
        "@mui/material": "^7.3.11",
        "@mui/system": "^7.3.11",
        "@mui/x-data-grid": "^8.28.7",
        "@mui/x-data-grid-pro": "^8.28.7",
        "@mui/x-date-pickers": "^8.28.7",
        "@mui/x-date-pickers-pro": "^8.28.7",
        "@mui/x-license": "^8.26.0",
        "@types/node": "^24.12.4",
        "apollo-link-rest": "^0.9.0",
        "date-fns": "^4.4.0",
        "final-form": "^4.20.10",
        "graphql": "^16.14.0",
        "history": "^4.10.1",
        "qs": "^6.15.2",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-final-form": "^6.5.9",
        "react-intl": "^7.1.11",
        "ts-dedent": "^2.2.0",
        "use-debounce": "^10.0.6",
        "uuid": "^11.1.1"
    },
    "devDependencies": {
        "@babel/cli": "^7.29.7",
        "@comet/admin-babel-preset": "workspace:*",
        "@comet/eslint-config": "workspace:*",
        "@faker-js/faker": "^10.4.0",
        "@graphql-mocks/network-msw": "^0.4.4",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-vitest": "10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@types/draft-js": "^0.11.20",
        "@types/history": "^4.7.11",
        "@types/qs": "^6.15.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@types/react-router": "^5.1.20",
        "@types/react-router-dom": "^5.3.3",
        "@vitest/browser": "4.1.8",
        "@vitest/browser-playwright": "4.1.8",
        "draft-js": "^0.11.7",
        "draft-js-export-html": "^1.4.1",
        "draft-js-export-markdown": "^1.4.0",
        "draft-js-import-markdown": "^1.4.1",
        "eslint": "^10.4.1",
        "eslint-plugin-storybook": "^10.3.5",
        "graphql-mocks": "^0.12.0",
        "immutable": "^3.8.2",
        "msw": "^2.14.6",
        "npm-run-all2": "^8.0.4",
        "playwright": "^1.49.1",
        "prettier": "^3.6.2",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-router": "^5.3.4",
        "react-router-dom": "^5.3.4",
        "remark-gfm": "^4.0.1",
        "storybook": "^10.3.5",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.8"
    },
    "msw": {
        "workerDirectory": "public"
    }
}
