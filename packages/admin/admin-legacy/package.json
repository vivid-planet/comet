{
    "name": "@comet/admin-legacy",
    "version": "9.0.0-beta.5",
    "description": "Comet Admin legacy/deprecated components",
    "repository": {
        "directory": "packages/admin/admin-legacy",
        "type": "git",
        "url": "https://github.com/vivid-planet/comet"
    },
    "license": "BSD-2-Clause",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "import": "./lib/index.js",
            "types": "./lib/index.d.ts"
        }
    },
    "files": [
        "lib"
    ],
    "scripts": {
        "build": "pnpm run clean && run-p build:babel build:types",
        "build:babel": "pnpm exec babel ./src -x \".ts,.tsx\" -d lib",
        "build:types": "tsc --project ./tsconfig.json --emitDeclarationOnly",
        "clean": "rimraf lib",
        "lint": "run-p lint:prettier lint:eslint lint:tsc",
        "lint:ci": "pnpm run lint",
        "lint:eslint": "eslint --max-warnings 0 src/ '**/*.json' --no-warn-ignored",
        "lint:fix": "run-p lint:fix:eslint lint:fix:prettier",
        "lint:fix:eslint": "pnpm run lint:eslint --fix",
        "lint:fix:prettier": "pnpm run lint:prettier --write",
        "lint:prettier": "pnpm exec prettier --check '*.{ts,js,json,md,yml,yaml}'",
        "lint:tsc": "tsc --noEmit",
        "start": "run-p start:babel start:types",
        "start:babel": "pnpm exec babel ./src -x \".ts,.tsx\" -d lib -w",
        "start:types": "tsc --project ./tsconfig.json --emitDeclarationOnly --watch --preserveWatchOutput",
        "test": "pnpm run test:unit",
        "test:unit": "vitest --run",
        "test:watch": "vitest --watch"
    },
    "dependencies": {
        "@comet/admin": "workspace:*",
        "@comet/admin-icons": "workspace:*",
        "exceljs": "^4.4.0",
        "lodash.debounce": "^4.0.8",
        "lodash.isequal": "^4.5.0",
        "query-string": "^7.1.3",
        "use-constant": "^2.0.0",
        "uuid": "^11.1.1"
    },
    "devDependencies": {
        "@apollo/client": "^3.14.1",
        "@babel/cli": "^7.29.7",
        "@babel/core": "^7.29.7",
        "@comet/admin-babel-preset": "workspace:*",
        "@comet/eslint-config": "workspace:*",
        "@comet/eslint-plugin": "workspace:*",
        "@mui/material": "^7.3.11",
        "@mui/system": "^7.3.11",
        "@types/lodash.debounce": "^4.0.9",
        "@types/lodash.isequal": "^4.5.8",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.39.4",
        "final-form": "^4.20.10",
        "graphql": "^16.14.0",
        "jsdom": "^28.1.0",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.6.2",
        "react": "^19.2.6",
        "react-dnd": "^16.0.1",
        "react-dom": "^19.2.6",
        "react-final-form": "^6.5.9",
        "react-intl": "^7.1.11",
        "rimraf": "^6.1.2",
        "typescript": "^5.9.3",
        "vitest": "^4.0.16"
    },
    "peerDependencies": {
        "@apollo/client": "^3.7.0",
        "@mui/material": "^7.0.0",
        "final-form": "^4.16.1",
        "graphql": "^14.0.0 || ^15.0.0 || ^16.0.0",
        "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
        "react-dnd": "^16.0.0",
        "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
        "react-final-form": "^6.3.1",
        "react-intl": "^5.0.0 || ^6.0.0 || ^7.0.0"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    }
}
