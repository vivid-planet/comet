{
    "name": "@comet/site-react",
    "version": "9.0.0-beta.2",
    "description": "Comet Site React package",
    "repository": {
        "type": "git",
        "url": "https://github.com/vivid-planet/comet",
        "directory": "packages/site/site-react"
    },
    "license": "BSD-2-Clause",
    "sideEffects": [
        "**/*.css"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.js"
        },
        "./css": "./lib/style.css",
        "./webpackPersistedQueriesLoader": "./lib/persistedQueries/webpackPersistedQueriesLoader.js"
    },
    "files": [
        "lib/*"
    ],
    "scripts": {
        "build": "pnpm run clean && pnpm run generate-block-types && vite build",
        "clean": "rimraf lib 'src/**/*.generated.ts'",
        "dev": "pnpm run clean && pnpm generate-block-types && vite build --watch",
        "generate-block-types": "comet generate-block-types",
        "generate-block-types:watch": "chokidar -s \"block-meta.json\" -c \"pnpm generate-block-types\"",
        "lint": "pnpm generate-block-types && run-p lint:prettier lint:eslint lint:tsc",
        "lint:ci": "pnpm run lint",
        "lint:eslint": "eslint --max-warnings 0 src/ '**/*.json' --no-warn-ignored",
        "lint:fix": "run-p lint:fix:eslint lint:fix:prettier",
        "lint:fix:eslint": "pnpm run lint:eslint --fix",
        "lint:fix:prettier": "pnpm run lint:prettier --write",
        "lint:prettier": "pnpm exec prettier --check '*.{ts,js,json,md,yml,yaml,css,scss}'",
        "lint:tsc": "tsc --noEmit",
        "test": "vitest --run",
        "test:watch": "vitest --watch"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "jose": "^5.10.0",
        "lodash.isequal": "^4.5.0",
        "scroll-into-view-if-needed": "^2.2.31",
        "usehooks-ts": "^3.1.1"
    },
    "devDependencies": {
        "@comet/cli": "workspace:*",
        "@comet/eslint-config": "workspace:*",
        "@types/draft-js": "^0.11.20",
        "@types/lodash.isequal": "^4.5.8",
        "@types/react": "^19.2.10",
        "@vitejs/plugin-react": "^4.7.0",
        "chokidar-cli": "^3.0.0",
        "eslint": "^9.39.2",
        "jsdom": "^28.0.0",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.6.2",
        "react": "^19.2.4",
        "rimraf": "^6.1.2",
        "rollup": "^4.44.2",
        "rollup-plugin-preserve-directives": "^0.4.0",
        "sass": "^1.89.2",
        "typescript": "^5.9.3",
        "vite": "^7.0.0",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.16",
        "webpack": "^5.102.1"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    }
}
