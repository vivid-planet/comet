{
    "extends": "../../tsconfig.core.json",
    "compilerOptions": {
        "target": "ES2024",
        "lib": ["ES2024"],
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "incremental": true,
        "strict": true,
        "strictPropertyInitialization": false,
        "strictNullChecks": true,
        "declarationMap": true,
        "useDefineForClassFields": false
    }
}
