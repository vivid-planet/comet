{
    "compilerOptions": {
        "outDir": "./lib",
        "paths": {
            "src/*": ["./src/*"]
        },
        "rootDir": "./src",
        "tsBuildInfoFile": "./lib/tsconfig.tsbuildinfo"
    },
    "exclude": ["node_modules", "lib"],
    "extends": "../tsconfig.base.json",
    "include": ["src/**/*"],
    "ts-node": {
        "files": true
    }
}
