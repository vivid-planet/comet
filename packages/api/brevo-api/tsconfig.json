{
    "compilerOptions": {
        "declarationMap": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "incremental": true,
        "lib": ["ES2023"],
        "outDir": "./lib",
        "paths": {
            "src/*": ["./src/*"]
        },
        "removeComments": true,
        "rootDir": "./src",
        "sourceMap": true,
        "strict": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": false,
        "target": "ES2023",
        "tsBuildInfoFile": "./lib/tsconfig.tsbuildinfo"
    },
    "exclude": ["node_modules", "lib"],
    "extends": "../tsconfig.base.json",
    "include": ["src/**/*"]
}
