{
    "name": "@comet/api-generator",
    "version": "9.0.0",
    "description": "Comet API Generator CLI tool",
    "repository": {
        "directory": "packages/api/api-generator",
        "type": "git",
        "url": "https://github.com/vivid-planet/comet"
    },
    "license": "BSD-2-Clause",
    "type": "commonjs",
    "main": "lib/apiGenerator.js",
    "typings": "lib/apiGenerator.d.ts",
    "bin": {
        "comet-api-generator": "bin/api-generator.js"
    },
    "sideEffects": false,
    "files": [
        "bin/**/*.js",
        "lib/*"
    ],
    "scripts": {
        "build": "pnpm run clean && tsc -p tsconfig.build.json",
        "clean": "rimraf lib",
        "dev": "tsc --watch --preserveWatchOutput -p tsconfig.build.json",
        "lint": "run-p lint:prettier lint:eslint lint:tsc",
        "lint:ci": "pnpm run lint",
        "lint:eslint": "eslint --max-warnings 0 src/ '**/*.json' --no-warn-ignored",
        "lint:fix": "run-p lint:fix:eslint lint:fix:prettier",
        "lint:fix:eslint": "pnpm run lint:eslint --fix",
        "lint:fix:prettier": "pnpm run lint:prettier --write",
        "lint:prettier": "pnpm exec prettier --check '*.{ts,js,json,md,yml,yaml}'",
        "lint:tsc": "tsc --noEmit",
        "test": "vitest --run",
        "test:updateSnapshot": "vitest --run --update",
        "test:watch": "vitest --watch"
    },
    "dependencies": {
        "@comet/cms-api": "workspace:*",
        "chokidar": "^4.0.3",
        "commander": "^9.5.0",
        "pluralize": "^8.0.0",
        "ts-morph": "^25.0.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@comet/eslint-config": "workspace:*",
        "@mikro-orm/cli": "^6.6.14",
        "@mikro-orm/core": "^6.6.14",
        "@mikro-orm/postgresql": "^6.6.14",
        "@nestjs/graphql": "^13.4.0",
        "@types/node": "^24.12.4",
        "@types/pluralize": "^0.0.33",
        "class-validator": "^0.15.1",
        "eslint": "^9.39.4",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.6.2",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.1.2",
        "unplugin-swc": "^1.5.9",
        "uuid": "^11.1.1",
        "vitest": "^4.1.8"
    },
    "peerDependencies": {
        "@mikro-orm/cli": "^6.0.0",
        "@mikro-orm/core": "^6.0.0",
        "@mikro-orm/postgresql": "^6.0.0",
        "@nestjs/graphql": "^13.0.0",
        "class-validator": "^0.14.0 || ^0.15.0"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    }
}
