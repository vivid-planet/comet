{
    "name": "@comet/cli",
    "version": "9.0.0-beta.1",
    "description": "A collection of CLI tools for Comet projects",
    "repository": {
        "directory": "packages/cli",
        "type": "git",
        "url": "https://github.com/vivid-planet/comet"
    },
    "license": "BSD-2-Clause",
    "type": "commonjs",
    "main": "lib/index.js",
    "typings": "lib/index.d.ts",
    "bin": {
        "comet": "bin/comet.js"
    },
    "files": [
        "bin/**/*.js",
        "lib/*"
    ],
    "scripts": {
        "build": "pnpm run clean && tsc",
        "clean": "rimraf lib",
        "dev": "tsc --watch",
        "lint": "run-p lint:prettier lint:eslint lint:tsc",
        "lint:ci": "pnpm run lint",
        "lint:eslint": "eslint --max-warnings 0 src/ '**/*.json' --no-warn-ignored",
        "lint:fix": "run-p lint:fix:eslint lint:fix:prettier",
        "lint:fix:eslint": "pnpm run lint:eslint --fix",
        "lint:fix:prettier": "pnpm run lint:prettier --write",
        "lint:prettier": "pnpm exec prettier --check '*.{ts,js,json,md,yml,yaml}'",
        "lint:tsc": "tsc",
        "test": "vitest --run",
        "test:watch": "vitest --watch"
    },
    "dependencies": {
        "commander": "^9.5.0",
        "js-yaml": "^4.1.0",
        "prettier": "^3.6.2",
        "ts-node": "^10.9.2"
    },
    "devDependencies": {
        "@comet/eslint-config": "workspace:*",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^24.12.0",
        "eslint": "^9.39.2",
        "npm-run-all2": "^8.0.4",
        "rimraf": "^6.1.2",
        "typescript": "^5.9.3",
        "vitest": "^4.0.16"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    }
}
