{
    "$schema": "https://swc.rs/schema.json",
    "sourceMaps": true,
    "module": {
        "type": "commonjs"
    },
    "jsc": {
        "target": "es2022",
        "parser": {
            "syntax": "typescript",
            "tsx": true,
            "decorators": true,
            "dynamicImport": true
        },
        "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true,
            "useDefineForClassFields": false,
            "react": {
                "runtime": "automatic"
            }
        },
        "keepClassNames": true,
        "baseUrl": ".",
        "paths": {
            "@src/*": ["src/*"]
        }
    }
}
