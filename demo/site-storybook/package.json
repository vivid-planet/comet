{
    "name": "comet-demo-site-storybook",
    "version": "1.0.0",
    "private": true,
    "description": "Storybook for Comet Demo Site components",
    "scripts": {
        "storybook": "storybook dev -p 26640 --no-version-updates --disable-telemetry",
        "build-storybook": "storybook build --disable-telemetry",
        "lint": "run-p lint:prettier lint:eslint lint:tsc",
        "lint:ci": "pnpm run lint",
        "lint:eslint": "eslint --max-warnings 0 .storybook/ ../site/src/**/*.stories.tsx --no-warn-ignored",
        "lint:fix": "run-p lint:fix:eslint lint:fix:prettier",
        "lint:fix:eslint": "pnpm run lint:eslint --fix",
        "lint:fix:prettier": "pnpm run lint:prettier --write",
        "lint:prettier": "pnpm exec prettier --check '*.{ts,js,json,md,yml,yaml}'",
        "lint:tsc": "tsc --noEmit"
    },
    "dependencies": {
        "@comet/site-nextjs": "workspace:*",
        "clsx": "^2.1.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-intl": "^7.1.11",
        "redraft": "^0.10.2"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.28.0",
        "@babel/preset-react": "^7.27.1",
        "@babel/preset-typescript": "^7.28.0",
        "@comet/eslint-config": "workspace:*",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-webpack5-compiler-babel": "^4.0.1",
        "@storybook/react-webpack5": "^10.3.5",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "babel-loader": "^10.0.0",
        "css-loader": "^7.1.2",
        "eslint": "^9.39.2",
        "eslint-plugin-storybook": "^10.3.5",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.6.2",
        "sass": "^1.89.5",
        "sass-loader": "^16.0.5",
        "storybook": "^10.3.5",
        "style-loader": "^4.0.0",
        "typescript": "^5.9.3"
    }
}
